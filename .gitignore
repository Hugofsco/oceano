# --- secrets & runtime config (NEVER commit) ---
oceano.env
.env

# --- runtime data: dbs, heartbeat, persisted web config (holds the bot token) ---
data/*
!data/.gitkeep

# --- agent workspace: screenshots, notes, scratch files ---
workspace/*
!workspace/.gitkeep

# --- logs ---
*.log
logs-*.txt

# --- python ---
venv/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/

# --- editor / OS / tooling ---
.claude/
.vscode/
.idea/
.DS_Store

# --- bundled models: large binaries fetched at install time, NOT committed
#     (GitHub rejects files >100MB; the whisper model alone is ~139MB). See assets/README.md.
assets/*
!assets/README.md

# --- llama.cpp now lives under the Oceano dir (build tree + GGUF models, ~tens of GB);
#     never commit it — GitHub caps files at 100MB and these are machine-built binaries.
llama.cpp/
