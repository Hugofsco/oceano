# Oceano secrets & runtime config — copy to `oceano.env` and fill in.
#   cp oceano.env.example oceano.env  &&  chmod 600 oceano.env
# Loaded by the systemd unit (oceano.service). KEEP oceano.env PRIVATE.

# Telegram bot token from @BotFather (Telegram -> message @BotFather -> /newbot).
# Optional — you can also set the token live in the web UI (Settings -> Telegram).
OCEANO_TELEGRAM_TOKEN=

# Comma-separated Telegram user IDs allowed to use the bot.
# The agent can run shell commands, so keep this tight. Empty = nobody.
# Don't know yours? Start the bot, message it, and it replies with your ID.
OCEANO_TELEGRAM_ALLOWED=

# Optional: ntfy topic for scheduled-task push notifications.
# Use a private, hard-to-guess topic. See oceano/scheduler.py for OCEANO_NTFY_URL.
OCEANO_NTFY_TOPIC=
